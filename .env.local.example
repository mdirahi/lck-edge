# Copy this file to .env.local (NEVER commit .env.local).
# Values come from your Supabase project Settings > API page.

# Public URL of your Supabase project, e.g. https://abcd1234.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# "anon" / "publishable" key (safe to expose to the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# "service_role" key (SERVER ONLY — bypasses row level security).
# Keep it secret. Never import this into client components.
SUPABASE_SERVICE_ROLE_KEY=
